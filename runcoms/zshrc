# uv run python shortcut
upy() { uv run python "$@"; }
if type compdef &>/dev/null; then
  compdef _python upy=python
fi

# Generate Pisces auth password from first commit hash
pisces_pw() {
  local repo="${1:-$HOME/dev/uni/uniclaw}"
  local hash
  hash=$(git -C "$repo" log --author="Pisces\|pisces" --reverse --format="%H" | head -1 | cut -c1-8)
  if [[ -z "$hash" ]]; then
    echo "Error: no Pisces commits found in $repo" >&2
    return 1
  fi
  echo -n "AugmentedMemories3.14${hash}" | shasum -a 256 | cut -c1-16 | tr -d '\n'
  echo '!P'
}

# ---------------------------------------------------------------------------
# Tool initializations (lazy-loaded where possible)
# ---------------------------------------------------------------------------

# NVM — eager PATH, lazy shell integration
# Add the default node's bin to PATH immediately (so npm/node/npx always work,
# including in just recipes and non-interactive subshells). Only the nvm command
# itself triggers the full nvm.sh load (~100ms), which you need for switching
# node versions.
export NVM_DIR="$HOME/.nvm"
if [[ -d "$NVM_DIR" ]]; then
  # Add default node to PATH without sourcing nvm.sh
  _nvm_default_bin=$(ls -d "$NVM_DIR"/versions/node/*/bin 2>/dev/null | sort -V | tail -1)
  [[ -n "$_nvm_default_bin" ]] && export PATH="$_nvm_default_bin:$PATH"
  unset _nvm_default_bin

  # Lazy-load only the nvm command itself
  nvm() {
    unfunction nvm 2>/dev/null
    [[ -s "$NVM_DIR/nvm.sh" ]] && . "$NVM_DIR/nvm.sh"
    [[ -s "$NVM_DIR/bash_completion" ]] && . "$NVM_DIR/bash_completion"
    nvm "$@"
  }
fi

# Conda — eager CONDA_PREFIX, lazy shell integration
# anaconda3/bin is on PATH via .zprofile, so python/pip/gpustat/maturin work.
# We also set CONDA_PREFIX eagerly so maturin can find the base environment.
# The full conda shell hook (~280ms) only loads when you run `conda activate`.
if [[ -d "$HOME/anaconda3" ]]; then
  export CONDA_PREFIX="$HOME/anaconda3"
elif [[ -d "$HOME/miniconda3" ]]; then
  export CONDA_PREFIX="$HOME/miniconda3"
fi

if [[ -n "${CONDA_PREFIX:-}" ]]; then
  conda() {
    unfunction conda
    __conda_setup="$("$CONDA_PREFIX/bin/conda" 'shell.zsh' 'hook' 2>/dev/null)"
    if [[ $? -eq 0 ]]; then
      eval "$__conda_setup"
    else
      [[ -f "$CONDA_PREFIX/etc/profile.d/conda.sh" ]] && . "$CONDA_PREFIX/etc/profile.d/conda.sh"
    fi
    unset __conda_setup
    conda "$@"
  }
fi

# Google Cloud SDK
